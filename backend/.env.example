# =============================================================================
# CONFIGURACION DEL SISTEMA - Dashboard de Control Logistico
# =============================================================================
# Copia este archivo como .env y rellena con tus datos reales
# NO subir el archivo .env al repositorio
# =============================================================================

# -----------------------------------------------------------------------------
# MYSQL - Base de datos de incidencias (opcional, si no se configura usa SQLite)
# -----------------------------------------------------------------------------
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=incidencias_dashboard
MYSQL_USER=root
MYSQL_PASSWORD=tu_contraseña_mysql

# -----------------------------------------------------------------------------
# ORACLE - Base de datos de usuarios activos (opcional)
# -----------------------------------------------------------------------------
ORACLE_JDBC_URL=jdbc:oracle:thin:@servidor:1521/servicio
ORACLE_USERNAME=usuario_oracle
ORACLE_PASSWORD=contraseña_oracle

# -----------------------------------------------------------------------------
# TEAMVIEWER - Control remoto (opcional)
# -----------------------------------------------------------------------------
TEAMVIEWER_PASSWORD=contraseña_teamviewer

# -----------------------------------------------------------------------------
# SSH - Acceso a dispositivos RFID (opcional)
# -----------------------------------------------------------------------------
RFID_SSH_USER=root
RFID_SSH_PASSWORD=contraseña_ssh

# -----------------------------------------------------------------------------
# FLASK - Configuracion del servidor web
# -----------------------------------------------------------------------------
FLASK_SECRET_KEY=cambia_esto_por_una_clave_secreta_larga_y_aleatoria
FLASK_HOST=0.0.0.0
FLASK_PORT=8503
FLASK_DEBUG=False

# -----------------------------------------------------------------------------
# SEGURIDAD
# -----------------------------------------------------------------------------
PASSWORD_SALT=cambia_esto_por_un_salt_aleatorio

# -----------------------------------------------------------------------------
# RUTAS - Archivos de configuracion
# -----------------------------------------------------------------------------
CSV_MESAS=../config/mesas.csv
CSV_RFID=../config/rfid.csv
OJDBC_JAR_PATH=ojdbc8.jar

# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=ping_server.log
